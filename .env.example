# Название приложения, отображается в заголовке FastAPI и в Swagger UI
APP_NAME=FastAPI Project

# Режим отладки. true — включает Swagger UI (/docs, /redoc, /openapi.json)
# для локальной разработки. false — обязательно для продакшена (документация
# API не должна быть публично доступна).
DEBUG=false

# Разрешённые источники (Origin) для CORS — с каких доменов браузеру можно
# делать запросы к этому API
CORS_ORIGINS=["http://localhost:3000"]

# Разрешённые HTTP-методы для CORS-запросов
CORS_METHODS=["GET", "POST", "PUT", "PATCH", "DELETE"]

# Разрешённые заголовки запроса для CORS
CORS_HEADERS=["Authorization", "Content-Type"]

# Хосты (значения заголовка Host), с которыми сервер согласится работать.
# Запросы с другим Host отклоняются с 400 (защита от Host header атак).
# "testserver" нужен, чтобы не ломать тесты через TestClient — его Host всегда такой.
ALLOWED_HOSTS=["localhost", "127.0.0.1", "testserver"]

# IP-адреса или подсети (CIDR), которым разрешён доступ к API.
# Пусто ([]) — ограничение отключено, доступ разрешён всем (по умолчанию).
# Пример: ALLOWED_IPS=["127.0.0.1", "203.0.113.10", "10.0.0.0/24"]
ALLOWED_IPS=[]

# Лимит запросов с одного IP-адреса, формат "<число>/<период>"
# (например: 100/minute, 10/second, 1000/hour)
RATE_LIMIT=100/minute

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Включает/выключает подключение к PostgreSQL. false — /postgre-check не
# пытается подключаться к базе (полезно, если PostgreSQL не поднят)
DB_ENABLED=true

# Хост базы данных (обычно localhost для локальной разработки)
DB_HOST=localhost

# Порт PostgreSQL (стандартный порт — 5432)
DB_PORT=5432

# Имя пользователя для подключения к БД
DB_USERNAME=postgres

# Пароль пользователя
DB_PASSWORD=postgres

# Название базы данных
DB_NAME=postgres

# Размер пула соединений SQLAlchemy к PostgreSQL (постоянно открытые соединения)
DB_POOL_SIZE=10

# Число дополнительных соединений сверх DB_POOL_SIZE при пиковой нагрузке
DB_MAX_OVERFLOW=5

# Включает/выключает подключение к Redis. false — /redis-check не
# пытается подключаться к Redis (полезно, если Redis не поднят)
REDIS_ENABLED=true

# Хост Redis (localhost при локальном запуске / запуске Redis через
# `docker run -p 6379:6379 ...`; при запуске через docker-compose.redis.yml
# переопределяется на имя сервиса "redis")
REDIS_HOST=localhost

# Порт Redis (стандартный порт — 6379)
REDIS_PORT=6379

# Пароль Redis. Пусто — без аутентификации (только для локальной разработки)
REDIS_PASSWORD=

# Номер логической базы Redis (0-15 по умолчанию)
REDIS_DB=0

# Максимальное число соединений в пуле Redis
REDIS_MAX_CONNECTIONS=20
